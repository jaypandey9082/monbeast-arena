# NEXT_PUBLIC variables are safe for frontend reads.
# PRIVATE_KEY is local deploy only.
# TRIPO_API_KEY is server-side only.
# ANTHROPIC_API_KEY is server-side only.
# Never expose secret keys with NEXT_PUBLIC.
# Never commit .env or .env.local.
# App must work without these keys using procedural 3D fallback.
# Use a fresh burner wallet for hackathon deployment.

NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadvision.com
NEXT_PUBLIC_MONBEAST_CONTRACT_ADDRESS=
NEXT_PUBLIC_FEATURED_MONBEAST_MODEL_URL=

PRIVATE_KEY=

TRIPO_API_KEY=
TRIPO_API_BASE=https://openapi.tripo3d.ai/v3
TRIPO_MODEL=v3.1-20260211

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
